# Copy this file to .env and fill in your values
APP_NAME="AI Mentor & Growth Planning System"
APP_VERSION="0.1.0"
DEBUG=false

DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ai_mentor_db

ALLOWED_ORIGINS=["http://localhost:5173"]

# OpenAI-compatible provider settings (Ark/Zhipu/etc.)
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_MODEL=
LLM_SYSTEM_PROMPT="You are a supportive university mentor."
RUN_LIVE_AI_TESTS=0

# JWT auth settings
AUTH_SECRET_KEY="change-me-in-production-with-a-long-secret-key"
AUTH_ALGORITHM="HS256"
AUTH_ACCESS_TOKEN_EXPIRES_MINUTES=120

# Optional startup admin bootstrap
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=
